{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parcheggia.local/schemas/api/prediction.schema.json",
  "title": "PredictionResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "segment_id",
    "parkability_score",
    "parkability_percent",
    "status",
    "trend",
    "confidence",
    "estimated_search_time_min",
    "recommendation"
  ],
  "properties": {
    "prediction_id": { "type": ["string", "null"] },
    "segment_id": { "type": "string" },
    "parkability_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "parkability_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
    "status": {
      "type": "string",
      "enum": ["very_difficult", "difficult", "uncertain", "good", "favorable"]
    },
    "trend": { "type": "string", "enum": ["better", "worse", "stable"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "estimated_search_time_min": { "type": "integer", "minimum": 0, "maximum": 120 },
    "recommendation": { "type": "string" },
    "parking_type": { "type": ["string", "null"], "enum": ["blue", "probable_free", "restricted", "unknown", null] },
    "parking_label": { "type": ["string", "null"] }
  }
}
